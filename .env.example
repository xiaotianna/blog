# Docker images
DOCKER_PLATFORM=linux/amd64
BLOG_NGINX_IMAGE=blog-nginx:latest
BLOG_FRONTEND_IMAGE=blog-frontend:latest
BLOG_BACKEND_IMAGE=blog-backend:latest

# Public site
NGINX_PORT=80
SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=blog
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=change_me
REDIS_PORT=6379
REDIS_DB=0

# Backend
ACCOUNT_PHONE=15583251761
ACCOUNT_PASSWORD=change_me
JWT_SECRET_KEY=change_me_to_a_long_random_string

# Backend container user. Keep 0:0 unless you know the target server uid/gid.
BACKEND_UID=0
BACKEND_GID=0
